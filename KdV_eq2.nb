Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"u", ",", "t", ",", "x"}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xmin", "=", 
   RowBox[{"-", "20"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xmax", "=", "20"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tmax", "=", "10"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eq", "=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"t", ",", "x"}], "]"}], ",", "t"}], "]"}], "==", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"u", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "3"}], "}"}]}], "]"}]}], "+", 
      RowBox[{"6", " ", 
       RowBox[{"u", "[", 
        RowBox[{"t", ",", "x"}], "]"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"u", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", "x"}], "]"}]}]}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ic", "=", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"0", ",", "x"}], "]"}], "==", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", 
       RowBox[{"x", "^", "2"}]}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"bc", "=", 
    RowBox[{"PeriodicBoundaryCondition", "[", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"t", ",", "x"}], "]"}], ",", 
      RowBox[{"x", "==", "xmin"}], ",", 
      RowBox[{"TranslationTransform", "[", 
       RowBox[{"{", 
        RowBox[{"xmax", "-", "xmin"}], "}"}], "]"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol2", "=", 
   RowBox[{"NDSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"eq", ",", "ic", ",", "bc"}], "}"}], ",", "u", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}], ",", 
     RowBox[{"Method", "->", 
      RowBox[{"{", "\"\<MethodOfLines\>\"", "}"}]}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982876703465755*^9, 3.982876703468562*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"ec713027-8153-4784-b0a3-da88b9536a1a"],

