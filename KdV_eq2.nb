Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "u", ",", "t", ",", "x", ",", "c", ",", "x0", ",", "xmin", ",", "xmax", ",",
      "tmax"}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"x0", "=", 
   RowBox[{"-", "10"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xmin", "=", 
   RowBox[{"-", "30"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xmax", "=", "30"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tmax", "=", "20"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eq", "=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"t", ",", "x"}], "]"}], ",", "t"}], "]"}], "==", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"u", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "3"}], "}"}]}], "]"}]}], "+", 
      RowBox[{"6", " ", 
       RowBox[{"u", "[", 
        RowBox[{"t", ",", "x"}], "]"}], " ", 
       RowBox[{"D", "[", 
        RowBox[{
         RowBox[{"u", "[", 
          RowBox[{"t", ",", "x"}], "]"}], ",", "x"}], "]"}]}]}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ic", "=", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"0", ",", "x"}], "]"}], "==", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"c", "/", "2"}], ")"}], " ", 
      RowBox[{
       RowBox[{"Sech", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "c", "]"}], "/", "2"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{"x", "-", "x0"}], ")"}]}], "]"}], "^", "2"}]}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"bc", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"t", ",", "xmin"}], "]"}], "==", "0"}], ",", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"t", ",", "xmax"}], "]"}], "==", "0"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "[", "u", "]"}], "[", 
        RowBox[{"t", ",", "xmin"}], "]"}], "==", "0"}]}], "}"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolveValue", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"eq", ",", "ic", ",", "bc"}], "}"}], ",", "u", ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
